# Salin file ini menjadi .env dan isi nilainya

# Token bot dari @BotFather (wajib)
BOT_TOKEN=your_bot_token_here

# ID admin awal, pisahkan dengan koma jika lebih dari satu (wajib)
# User ID bisa dicek via @userinfobot di Telegram
# Setelah bot berjalan, admin bisa menambah admin lain via /addadmin
ADMIN_IDS=123456789,987654321

# URL koneksi database PostgreSQL dari Neon.tech (opsional)
# Jika tidak diisi, bot akan pakai SQLite lokal (untuk dev/testing saja)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
